# Copy to .env and adjust values as needed.

# Server
PORT=8080
GIN_MODE=release

# Upstream sources
LM_SOURCE_URL=https://emasantam.id/content/lm.txt
ANTAREMAS_SOURCE_URL=https://antaremas.com/harga-emas
GALERI24_SOURCE_URL=https://galeri24.co.id/harga-emas

# Cache TTL for upstream scrapes in seconds. Set to 0 to disable caching.
CACHE_TTL_SECOND=60

# Basic Auth for higher rate limits (optional)
# If either is empty, all requests are treated as unauthenticated.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=secret

# Rate limiting (requests per minute, per client IP)
RATE_LIMIT_UNAUTHORIZED_PER_MINUTE=1
RATE_LIMIT_AUTHORIZED_PER_MINUTE=100

